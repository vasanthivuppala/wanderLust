<% layout("/layouts/boilerplate") -%>
<div class="row">
    <div class="col-8 offset-2">
        <h3>Edit your listing</h3>
    <form method="POST" action="/listings/<%= listing._id%>?_method=PUT" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="title" class="form-label">Edit Title</label>
             <input name="listing[title]" value="<%= listing.title%>" type="text" class="form-control" required/>
        </div>
        <div class="valid-feedback">
           Title looks good!
        </div>
        <div class="mb-3">
             <label for="description" class="form-label">Edit Description</label>
             <input name="listing[description]" value="<%= listing.description%>" type="text" class="form-control" required/>
            <div class="invalid-feedback">
           Please enter a valid description
        </div>   
        </div>
         <div class="mb-3">
            <label for="image" class="form-label">Edit Image</label>
            <input name="listing[image]" value="<%= listing.image%>" type="text" placeholder="Enter image URL?Link" class="form-control" required/>
         </div>
         <div class="row">
         <div class="mb-3 col-md-4 ">
              <label for="price" class="form-label">Edit price</label>
              <input name="listing[price]" value="<%= listing.price%>"  class="form-control" required/>
                <div class="invalid-feedback">
           Please enter a valid price
        </div>
         </div>
        <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" value="<%= listing.country%>" type="text"class="form-control" required/>
              <div class="invalid-feedback">
           Please enter a valid country
        </div>
        </div>
        </div>
         <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
    </div>
    </div>

